#!/usr/bin/env bash
set -euo pipefail

output_format="text"

if [[ "${1:-}" == "--json" ]]; then
  output_format="json"
  shift
fi
readonly output_format

first_release_version="${1:-}"
readonly first_release_version
version_manifest_url="https://launchermeta.mojang.com/mc/game/version_manifest_v2.json"
readonly version_manifest_url

if [[ -z "$first_release_version" ]]; then
  echo "Usage: $0 [--json] <first-release-version>" >&2
  exit 1
fi

if [[ "$output_format" == "json" ]]; then
  curl -fsSL --retry 5 --retry-all-errors --connect-timeout 15 --max-time 60 "$version_manifest_url" \
    | jq -c --arg firstReleaseVersion "$first_release_version" '
      ([.versions[] | select(.type == "release") | .id] | reverse) as $releaseVersions |
      ($releaseVersions | index($firstReleaseVersion)) as $firstReleaseVersionIndex |
      if $firstReleaseVersionIndex == null
      then error("Release version not found: \($firstReleaseVersion)")
      else $releaseVersions[$firstReleaseVersionIndex:]
      end
    '
else
  curl -fsSL --retry 5 --retry-all-errors --connect-timeout 15 --max-time 60 "$version_manifest_url" \
    | jq -r --arg firstReleaseVersion "$first_release_version" '
      ([.versions[] | select(.type == "release") | .id] | reverse) as $releaseVersions |
      ($releaseVersions | index($firstReleaseVersion)) as $firstReleaseVersionIndex |
      if $firstReleaseVersionIndex == null
      then error("Release version not found: \($firstReleaseVersion)")
      else $releaseVersions[$firstReleaseVersionIndex:] | .[]
      end
    '
fi
