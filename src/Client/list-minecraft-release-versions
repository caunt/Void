#!/usr/bin/env bash
set -euo pipefail

outputFormat="lines"
firstReleaseVersion="1.7.2"

while [ "$#" -gt 0 ]; do
    case "$1" in
        --json)
            outputFormat="json"
            shift
            ;;
        *)
            firstReleaseVersion="$1"
            shift
            ;;
    esac
done

versionFilter='
  ([.versions[] | select(.type == "release") | .id] | reverse) as $releaseVersions
  | ($releaseVersions | index($firstReleaseVersion)) as $firstReleaseVersionIndex
  | if $firstReleaseVersionIndex == null then error("First release version not found: \($firstReleaseVersion)") else $releaseVersions[$firstReleaseVersionIndex:] end
'

jqOutputArgument="-r"
jqFilter="$versionFilter | .[]"

if [ "$outputFormat" = "json" ]; then
    jqOutputArgument="-c"
    jqFilter="$versionFilter"
fi

curl -fsSL https://launchermeta.mojang.com/mc/game/version_manifest_v2.json | jq "$jqOutputArgument" --arg firstReleaseVersion "$firstReleaseVersion" "$jqFilter"
